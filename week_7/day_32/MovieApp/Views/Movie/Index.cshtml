@model List<MovieApp.Models.Movie>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2> Movie List</h2>
        <a href="/Movie/Create" class="btn btn-primary">
             Add New Movie
        </a>
    </div>

    <div class="card shadow p-3">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Genre</th>
                    <th>Price</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Genre</td>
                        <td>@item.Price</td>
                        <td>
                            <a href="/Movie/Edit/@item.Id" class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <a href="/Movie/Delete/@item.Id" class="btn btn-sm btn-danger">
                                Delete
                            </a>

                            <a href="/Movie/Details/@item.Id" class="btn btn-sm btn-info">
                                Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>