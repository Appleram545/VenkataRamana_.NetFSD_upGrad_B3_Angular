
@model AbcInfotech.Models.ContactInfo

<h2 class=" mt-3 mb-4">Your Searched Result</h2>

@if(Model!=null){
    
    <p><b>Contact ID:</b> @Model.ContactId</p>
    <p><b>First Name:</b> @Model.FirstName</p>
    <p><b>Last Name:</b> @Model.LastName</p>
    <p><b>Company:</b> @Model.CompanyName</p>
    <p><b>Email:</b> @Model.Email</p>
    <p><b>Phone:</b> @Model.Phone</p>
    <p><b>Designation:</b> @Model.Designation</p>
}
else{
    <p class="text-danger fw-bold"> @ViewBag.Message</p>
}

<a href="/Contact/ShowDetails" class="btn btn-secondary">GO Back</a>

