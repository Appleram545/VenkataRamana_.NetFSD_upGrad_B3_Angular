@model List<College.Models.Course>

<h2>Course List</h2>

<a href="/Course/Create">Add New Course</a>

<table border="1">
    <tr>
        <th>Course Id</th>
        <th>Course Name</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseId</td>
            <td>@item.CourseName</td>
        </tr>
    }
</table>