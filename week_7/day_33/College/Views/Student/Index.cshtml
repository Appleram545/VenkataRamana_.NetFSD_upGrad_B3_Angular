@model List<College.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add Student</a>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Course</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Course.CourseName</td>
        </tr>
    }
</table>