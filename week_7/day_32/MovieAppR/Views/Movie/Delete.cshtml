@model MovieAppR.Models.Movie

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto" style="max-width: 450px;">

        <h3 class="text-center text-danger mb-3">Delete Movie</h3>
        <p class="text-center">Are you sure you want to delete this?</p>

        <div class="mb-3">
            <p><strong>Title:</strong> @Model.Title</p>
            <p><strong>Genre:</strong> @Model.Genre</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a href="/Movie" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </form>

    </div>
</div>