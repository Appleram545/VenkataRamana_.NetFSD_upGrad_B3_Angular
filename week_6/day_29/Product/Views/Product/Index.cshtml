@using Product.Models
@model List<ProductItems>

    <h2>Product List</h2>
    <hr>
    <a class="btn btn-primary" asp-action="Add">Add New Product</a>

<table border="1" cellpadding="10" cellspacing="5" table-bordered>


<thead>
    <tr>
        <td>Product Id</td>
        <td>Name</td>
        <td>Price</td>
        <td>Category</td>
    </tr>
</thead>
<tbody>
    @foreach(var p in Model){
          <tr>
            <td>@p.productId</td>
            <td>@p.name</td>
            <td>@p.price</td>
            <td>@p.category</td>
            <td>
                    <a asp-action="Details" asp-controller="Product" asp-route-id="@p.productId">Details</a>
               <a asp-action="Edit" asp-controller="Product" asp-route-id="@p.productId">Edit</a>
               <a asp-action="Delete" asp-controller="Product" asp-route-id="@p.productId">Delete</a>
            </td>
            </tr>
            
    }
</tbody>
    </table>