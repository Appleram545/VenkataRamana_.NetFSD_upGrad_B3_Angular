@model IEnumerable<ContactInfo>

<h2 class="mb-3">Contact List</h2>

<p>
    <a asp-action="Create" class="btn btn-primary"> Add New Contact</a>
</p>

<table class="table table-bordered table-striped table-hover">
    <thead >
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Company</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FirstName @item.LastName</td>
                <td>@item.EmailId</td>
                <td>@item.MobileNo</td>
                <td>@item.CompanyName</td>
                <td>@item.DepartmentName</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.ContactId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ContactId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>